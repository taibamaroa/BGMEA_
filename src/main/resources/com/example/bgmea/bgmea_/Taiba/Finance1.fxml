<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="448.0" prefWidth="603.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.Taiba.Finance1">

    <children>

        <!-- Title -->
        <Label layoutX="204.0" layoutY="23.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text=" Membership Renewal" textFill="#1bb74f" />

        <!-- Factory ID -->
        <Label layoutX="50" layoutY="80" text="Factory ID:" />
        <TextField fx:id="factoryIdField" layoutX="150" layoutY="75" prefWidth="200" />

        <!-- Dues -->
        <Label layoutX="50" layoutY="120" text="Dues:" />

        <!-- Payment -->
        <Label layoutX="50" layoutY="160" text="Payment Amount:" />
        <TextField fx:id="paymentField" layoutX="150" layoutY="155" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="118.0" layoutY="200.0" onAction="#ConfirmPaymentbtn" text="Confirm Payment" />


        <TableView fx:id="paymentTable" layoutX="50.0" layoutY="278.0" prefHeight="120" prefWidth="500">

            <columns>
                <TableColumn fx:id="colFactoryId" prefWidth="113.59998321533203" text="Factory ID" />
                <TableColumn fx:id="colAmount" prefWidth="142.4000244140625" text="Amount Paid" />
                <TableColumn fx:id="colDate" prefWidth="48.6666259765625" text="Date" />
                <TableColumn fx:id="Coldues" prefWidth="119.3333740234375" text="Dues" />
            </columns>

        </TableView>
        <Button layoutX="474.0" layoutY="398.0" onAction="#returnBtn" text="Return Home" textFill="#1bb74f" />
        <Label fx:id="statuslabel" layoutX="156.0" layoutY="424.0" prefHeight="18.0" prefWidth="174.0" />
        <TextField fx:id="duesTF" layoutX="150.0" layoutY="116.0" prefWidth="200" />
        <Label layoutX="300.0" layoutY="204.0" text="Date :" />
        <DatePicker fx:id="datepicker" layoutX="347.0" layoutY="200.0" />

    </children>
</AnchorPane>
