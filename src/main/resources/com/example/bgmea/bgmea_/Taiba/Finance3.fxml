<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="456.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.Taiba.Finance3">

    <children>

        <!-- Title -->
        <Label layoutX="209.0" layoutY="25.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Welfare Fund Payout" textFill="#1bb74f" />

        <!-- TableView for Approved Claims -->
        <TableView fx:id="claimsTable" layoutX="55.0" layoutY="228.0" prefHeight="150" prefWidth="382.0">

            <columns>
                <TableColumn fx:id="colClaimId" prefWidth="120" text="Claim ID" />
                <TableColumn fx:id="colAmount" prefWidth="120" text="Amount" />
                <TableColumn fx:id="colStatus" prefWidth="140" text="Status" />
            </columns>

        </TableView>

        <!-- Bank Account Input -->
        <Label layoutX="72.0" layoutY="149.0" text="Bank Account:" />
        <TextField fx:id="bankField" layoutX="182.0" layoutY="144.0" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="182.0" layoutY="189.0" onAction="#executeTransferbtn" text="Execute Transfer" />
        <TextField fx:id="cliamidTF" layoutX="172.0" layoutY="69.0" />
        <Label layoutX="72.0" layoutY="73.0" text="Claim ID :" />
        <Label fx:id="statuslabel" layoutX="147.0" layoutY="393.0" prefHeight="18.0" prefWidth="200.0" />
        <Button layoutX="470.0" layoutY="402.0" onAction="#returnBtn" text="Return Home" textFill="#1bb74f" />
        <TextField fx:id="amountTF" layoutX="172.0" layoutY="106.0" />
        <Label layoutX="72.0" layoutY="110.0" text="Amount :" />

    </children>
</AnchorPane>