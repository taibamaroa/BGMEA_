<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="359.0" prefWidth="578.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.Taiba.HR8">

    <children>

        <!-- Title -->
        <Label layoutX="232.0" layoutY="25.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Factory Status Change" textFill="#1bb74f" />

        <!-- Event 1: Search Factory -->
        <Label layoutX="57.0" layoutY="83.0" text="Factory ID" />
        <TextField fx:id="factoryIdField" layoutX="157.0" layoutY="78.0" prefWidth="150" />

        <Button layoutX="422.0" layoutY="127.0" onAction="#searchBtn" text="Search" />

        <!-- Event 2: Change Status -->
        <Label layoutX="57.0" layoutY="143.0" text="Status" />
        <ComboBox fx:id="statusCombo" layoutX="157.0" layoutY="138.0" prefWidth="150" />

        <!-- Event 3: Update -->
        <Button layoutX="157.0" layoutY="193.0" onAction="#updateBtn" text="Update Status" />

        <!-- Timestamp Output -->
        <Label layoutX="54.0" layoutY="252.0" text="Last Updated" />
        <Label fx:id="timeLabel" layoutX="157.0" layoutY="243.0" text="" />

        <!-- Status Message -->
        <Label fx:id="msgLabel" layoutX="150" layoutY="270" prefHeight="18.0" prefWidth="196.0" text="" />
        <Button layoutX="422.0" layoutY="288.0" onAction="#returnBtn" text="Return Home" textFill="#1bb74f" />

    </children>
</AnchorPane>