<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="485.0" prefWidth="668.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.Taiba.Finance2">

    <children>

        <!-- Title -->
        <Label layoutX="247.0" layoutY="27.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text=" Approve UD Fees" textFill="#1bb74f" />

        <!-- TableView for Pending Fees -->
        <TableView fx:id="pendingTable" layoutX="64.0" layoutY="152.0" prefHeight="150" prefWidth="500">

            <columns>
                <TableColumn fx:id="colFactoryId" prefWidth="120" text="Factory ID" />
                <TableColumn fx:id="colAmount" prefWidth="120" text="Amount" />
                <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
                <TableColumn fx:id="colDate" prefWidth="140" text="Date" />
            </columns>

        </TableView>

        <!-- Bank Transaction ID -->
        <Label layoutX="64.0" layoutY="322.0" text="Bank Trans-ID:" />
        <TextField fx:id="transIdField" layoutX="174.0" layoutY="317.0" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="211.0" layoutY="360.0" onAction="#ApproveFeebtn" text="Approve Fee" />
        <Button layoutX="514.0" layoutY="442.0" onAction="#returnBtn" text="Return Home" textFill="#1bb74f" />
        <Button layoutX="215.0" layoutY="110.0" onAction="#loadinfobtn" prefHeight="26.0" prefWidth="186.0" text="Load Info" />
        <Label fx:id="msglabel" layoutX="258.0" layoutY="415.0" prefHeight="18.0" prefWidth="151.0" />

    </children>
</AnchorPane>