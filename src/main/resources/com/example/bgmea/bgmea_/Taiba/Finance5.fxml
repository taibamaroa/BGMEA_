<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.Taiba.Finance5">

    <children>

        <!-- Title -->
        <Label layoutX="200" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Expense Tracking" textFill="#1bb74f" />

        <!-- Expense Description -->
        <Label layoutX="50" layoutY="80" text="Description:" />
        <TextArea fx:id="descriptiontextArea" layoutX="150" layoutY="75" prefHeight="80" prefWidth="300" />

        <!-- Bill Amount -->
        <Label layoutX="50" layoutY="180" text="Bill Amount:" />
        <TextField fx:id="amountField" layoutX="150" layoutY="175" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="150" layoutY="220" onAction="#PostLedgerbtn" text="Post to Ledger" />

        <!-- Status -->
        <Label fx:id="statusLabel" layoutX="152.0" layoutY="280.0" style="-fx-text-fill: green; -fx-font-weight: bold;" text="Status: Pending" />
        <Button layoutX="420.0" layoutY="330.0" onAction="#returnBtn" text="Return Home" textFill="#1bb74f" />

    </children>
</AnchorPane>