<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.Taiba.HR2">

    <children>

        <!-- Title -->
        <Label layoutX="233.0" layoutY="23.0" prefHeight="26.0" prefWidth="200.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Factory Audit Update" textFill="#1bb74f" />

        <!-- Event 1: Audit Tab (simulated as section title) -->
        <Label layoutX="45.0" layoutY="49.0" style="-fx-font-weight:bold;" text="Audit Section" />

        <!-- Event 2: Search Factory -->
        <Label layoutX="30" layoutY="90" text="Factory ID" />
        <TextField fx:id="factoryIdField" layoutX="120" layoutY="85" />

        <Button layoutX="223.0" layoutY="303.0" onAction="#searchBtn" prefHeight="26.0" prefWidth="110.0" text="Search" />

        <Label layoutX="30" layoutY="130" text="Factory Name:" />

        <Label layoutX="30" layoutY="160" text="Location:" />

        <!-- Event 3: Audit Input -->
        <Label layoutX="24.0" layoutY="242.0" text="Safety Findings" />
        <TextArea fx:id="auditArea" layoutX="144.0" layoutY="242.0" prefHeight="48.0" prefWidth="200" />

        <!-- Event 4: Save -->
        <Button layoutX="118.0" layoutY="200.0" onAction="#saveBtn" prefHeight="26.0" prefWidth="230.0" text="Save Audit" />

        <Label fx:id="statusLabel" layoutX="259.0" layoutY="345.0" prefHeight="18.0" prefWidth="109.0" text="" />

        <TableView fx:id="auditTable" layoutX="386.0" layoutY="133.0" prefHeight="134.0" prefWidth="300">

            <columns>
                <TableColumn fx:id="colId" text="Factory ID" />
                <TableColumn fx:id="colName" prefWidth="94.39993286132812" text="Name" />
                <TableColumn fx:id="colFindings" prefWidth="125.5999755859375" text="Findings" />
            </columns>

        </TableView>
        <TextField fx:id="factorynmField" layoutX="120.0" layoutY="117.0" />
        <TextField fx:id="LocationfD" layoutX="120.0" layoutY="156.0" />
        <Button layoutX="557.0" layoutY="329.0" onAction="#returnBtn" text="Return Home" textFill="#1bb74f" />

    </children>
</AnchorPane>