<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.Qualityinspectorgoal7">

    <children>

        <!-- Title -->
        <Label layoutX="150" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Upload Inspection Photos" textFill="#0c87cf" />

        <!-- TableView: Batch List -->
        <TableView fx:id="batchTable" layoutX="63.0" layoutY="144.0" prefHeight="111.0" prefWidth="430.0">

            <columns>
                <TableColumn fx:id="colBatchId" prefWidth="138.4000244140625" text="Batch ID" />
                <TableColumn fx:id="colStatus" minWidth="0.0" prefWidth="151.20001220703125" text="Status" />
                <TableColumn fx:id="colDate" prefWidth="139.199951171875" text="Date" />
            </columns>

        </TableView>

        <!-- Upload Button -->
        <Button layoutX="202.0" layoutY="320.0" onAction="#UploadPhotoBtn" text="Upload Photo" />

        <!-- Status Message -->
        <Label fx:id="statusLabel" layoutX="200" layoutY="280" style="-fx-text-fill: red; -fx-font-weight:bold;" text="No file uploaded" />
        <Button layoutX="224.0" layoutY="87.0" mnemonicParsing="false" onAction="#showdataBtn" text="show data" />
        <Button layoutX="421.0" layoutY="333.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />

    </children>
</AnchorPane>