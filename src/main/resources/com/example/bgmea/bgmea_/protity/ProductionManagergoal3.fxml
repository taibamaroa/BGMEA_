<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.ProductionManagergoal3">

    <children>

        <!-- Title -->
        <Label layoutX="180" layoutY="20" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Machine Maintenance Scheduling" textFill="#0c87cf" />

        <!-- Machine Selection -->
        <Label layoutX="80" layoutY="100" text="Select Machine:" />
        <ComboBox fx:id="machineBox" layoutX="220" layoutY="95" prefWidth="200" />

        <!-- Last Maintenance -->
        <Label layoutX="80" layoutY="150" text="Last Maintenance:" />
        <Label fx:id="lastDateLabel" layoutX="220" layoutY="150" text="N/A" />

        <!-- Next Maintenance -->
        <Label layoutX="80" layoutY="200" text="Next Maintenance:" />
        <DatePicker fx:id="nextDatePicker" layoutX="220" layoutY="195" />

        <!-- Button -->
        <Button layoutX="220" layoutY="260" onAction="#ScheduleBtn" text="Schedule Maintenance" />

        <!-- Status -->
        <Label fx:id="statusLabel" layoutX="200" layoutY="320" style="-fx-text-fill: blue; -fx-font-weight: bold;" text="Status: Waiting" />

        <!-- Return Button -->
        <Button layoutX="520" layoutY="420" onAction="#ReturnHome" text="Return Home" textFill="#0c87cf" />

    </children>
</AnchorPane>