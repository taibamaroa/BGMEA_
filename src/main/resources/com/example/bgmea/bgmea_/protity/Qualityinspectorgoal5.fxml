<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="581.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.Qualityinspectorgoal5">

    <children>

        <!-- Title -->
        <Label layoutX="178.0" layoutY="48.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Monitor Rejected Batches" textFill="#0c87cf" />

        <!-- TableView for Rejected Batches -->
        <TableView fx:id="rejectedTable" layoutX="39.0" layoutY="256.0" prefHeight="150" prefWidth="500">

            <columns>
                <TableColumn fx:id="colBatchId" prefWidth="120" text="Batch ID(new)" />
                <TableColumn fx:id="colDate" prefWidth="120" text="Date" />
                <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
                <TableColumn fx:id="colAction" prefWidth="140" text="Corrective Action" />
            </columns>

        </TableView>

        <!-- Rejection Reason -->
        <Label layoutX="48.0" layoutY="424.0" text="Rejection Reason:" />
        <TextArea fx:id="reasonArea" layoutX="178.0" layoutY="419.0" prefHeight="57.0" prefWidth="289.0" />

        <!-- Verify Status -->
        <Label layoutX="48.0" layoutY="514.0" text="Action Status:" />
        <Label fx:id="StatusLabel" layoutX="142.0" layoutY="549.0" style="-fx-text-fill: blue; -fx-font-weight: bold;" text="Pending" />
        <Button layoutX="435.0" layoutY="523.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />
        <Button layoutX="249.0" layoutY="489.0" mnemonicParsing="false" onAction="#rejectdata" text="Reject Data" />
        <Label layoutX="68.0" layoutY="118.0" text="Batch ID:" />
        <TextField fx:id="batchIdField" layoutX="168.0" layoutY="113.0" prefWidth="200" />
        <Label layoutX="68.0" layoutY="155.0" text="Date :" />
        <Label layoutX="68.0" layoutY="201.0" text="Corrective Action :" />
        <TextField fx:id="cureectiveTF" layoutX="185.0" layoutY="197.0" prefWidth="200" />
        <DatePicker fx:id="datepicker" layoutX="143.0" layoutY="151.0" />

    </children>
</AnchorPane>