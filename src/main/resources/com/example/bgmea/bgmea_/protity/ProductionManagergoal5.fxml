<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0" prefWidth="754.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.ProductionManagergoal5">

    <!-- ToggleGroups MUST be declared here -->
    <fx:define>
        <ToggleGroup fx:id="shiftGroup" />
        <ToggleGroup fx:id="availabilityGroup" />
    </fx:define>

    <children>

        <!-- Title -->
        <Label layoutX="220" layoutY="20" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Worker Shift Assignment" textFill="#0c87cf" />

        <!-- Worker Info -->
        <Label layoutX="50" layoutY="100" text="Worker ID:" />
        <TextField fx:id="idTF" layoutX="140" layoutY="95" />

        <Label layoutX="50" layoutY="140" text="Name:" />
        <TextField fx:id="NameTF" layoutX="140" layoutY="135" />

        <!-- Department -->
        <Label layoutX="350" layoutY="100" text="Department:" />
        <ComboBox fx:id="departmentBox" layoutX="450" layoutY="95" prefWidth="180" />

        <!-- Shift Selection -->
        <Label layoutX="50" layoutY="190" text="Shift:" />

        <RadioButton layoutX="140" layoutY="190"
                     text="Morning"
                     toggleGroup="$shiftGroup" />

        <RadioButton layoutX="230" layoutY="190"
                     text="Evening"
                     toggleGroup="$shiftGroup" />

        <RadioButton layoutX="320" layoutY="190"
                     text="Night"
                     toggleGroup="$shiftGroup" />
        <!-- Availability -->
        <Label layoutX="432.0" layoutY="190.0" text="Available:" />

        <RadioButton layoutX="499.0" layoutY="190.0"
                     text="Yes"
                     toggleGroup="$availabilityGroup" />

        <RadioButton layoutX="569.0" layoutY="190.0"
                     text="No"
                     toggleGroup="$availabilityGroup" />
        <!-- Table -->
        <TableView fx:id="workerTable" layoutX="50" layoutY="250" prefHeight="150" prefWidth="600">
            <columns>
                <TableColumn fx:id="colId" prefWidth="150" text="Worker ID" />
                <TableColumn fx:id="colName" prefWidth="150" text="Name" />
                <TableColumn fx:id="colSkill" prefWidth="150" text="Skill" />
                <TableColumn fx:id="colAvailable" prefWidth="150" text="Available" />
            </columns>
        </TableView>

        <!-- Buttons -->
        <Button layoutX="200" layoutY="420" onAction="#AssignShiftBtn" text="Assign Shift" />
        <Button layoutX="350" layoutY="420" onAction="#saveBtn" text="Save Information" />
        <Button layoutX="554.0" layoutY="457.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />

        <!-- Status -->
        <Label fx:id="statusLabel" layoutX="250" layoutY="470" style="-fx-text-fill: blue; -fx-font-weight:bold;" text="Status: Waiting" />

    </children>
</AnchorPane>