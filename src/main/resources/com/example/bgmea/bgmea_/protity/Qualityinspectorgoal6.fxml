<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.Qualityinspectorgoal6">

    <children>

        <!-- Title -->
        <Label layoutX="160" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Schedule Re-inspection" textFill="#0c87cf" />

        <!-- TableView: Rejected Batches -->
        <TableView fx:id="batchTable" layoutX="50" layoutY="60" prefHeight="150" prefWidth="500">

            <columns>
                <TableColumn fx:id="colBatchId" prefWidth="150" text="Batch ID" />
                <TableColumn fx:id="colStatus" prefWidth="150" text="Status" />
                <TableColumn fx:id="colDate" prefWidth="200" text="Rejected Date" />
            </columns>

        </TableView>

        <!-- Date Selection -->
        <Label layoutX="50" layoutY="230" text="Re-inspection Date:" />
        <DatePicker fx:id="reinspectDate" layoutX="200" layoutY="225" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="200" layoutY="270" onAction="#ScheduleBtn" text="Schedule" />

        <!-- Confirmation Message -->
        <Label fx:id="messageLabel" layoutX="200" layoutY="320" style="-fx-text-fill: blue; -fx-font-weight:bold;" text="Waiting..." />
        <Button layoutX="447.0" layoutY="339.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />

    </children>
</AnchorPane>