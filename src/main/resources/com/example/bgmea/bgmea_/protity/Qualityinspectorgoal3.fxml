<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="510.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.Qualityinspectorgoal3">

    <children>

        <!-- Title -->
        <Label layoutX="171.0" layoutY="46.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Approve / Reject Batch" textFill="#0c87cf" />

        <!-- TableView: Inspection List -->
        <TableView fx:id="batchTable" layoutX="28.0" layoutY="208.0" prefHeight="140" prefWidth="543.0">

            <columns>
                <TableColumn fx:id="colBatchId" prefWidth="120" text="Batch ID" />
                <TableColumn fx:id="colname" prefWidth="155.20001220703125" text="Batch Name" />
                <TableColumn fx:id="colStatus" prefWidth="128.0" text="Status" />
                <TableColumn fx:id="colResult" prefWidth="140.00006103515625" text="Inspection Result" />
            </columns>

        </TableView>

        <!-- Decision -->
        <Label layoutX="83.0" layoutY="150.0" text="Decision:" />
        <ComboBox fx:id="decisionBox" layoutX="171.0" layoutY="150.0" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="239.0" layoutY="101.0" onAction="#UpdateStatusBtn" text="Update Status" />

        <!-- Confirmation Message -->
        <Label fx:id="messageLabel" layoutX="184.0" layoutY="443.0" style="-fx-text-fill: blue; -fx-font-weight:bold;" text="Waiting..." />
        <Button layoutX="450.0" layoutY="439.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />

    </children>
</AnchorPane>
