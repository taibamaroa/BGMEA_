<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.Qualityinspectorgoal4">

    <children>

        <!-- Title -->
        <Label layoutX="160" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Generate Quality Report" textFill="#0c87cf" />

        <!-- Report Type -->
        <Label layoutX="50" layoutY="80" text="Report Type:" />
        <ChoiceBox fx:id="reportTypeChoicebox" layoutX="180" layoutY="75" prefWidth="200" />

        <!-- Date Range -->
        <Label layoutX="50" layoutY="120" text="From:" />
        <DatePicker fx:id="fromDate" layoutX="180" layoutY="115" prefWidth="200" />

        <Label layoutX="50" layoutY="160" text="To:" />
        <DatePicker fx:id="toDate" layoutX="180" layoutY="155" prefWidth="200" />

        <!-- Buttons -->
        <Button layoutX="180" layoutY="200" onAction="#GenerateReportBtn" text="Generate Report" />

        <!-- Report Summary -->
        <Label layoutX="50" layoutY="250" text="Report Summary:" />
        <TextArea fx:id="reportArea" layoutX="150.0" layoutY="250.0" prefHeight="64.0" prefWidth="297.0" />
        <Button layoutX="429.0" layoutY="360.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />
        <Label fx:id="statusLabel" layoutX="180.0" layoutY="343.0" prefHeight="18.0" prefWidth="136.0" />

    </children>
</AnchorPane>
