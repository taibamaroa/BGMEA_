<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.Qualityinspectorgoal8">

    <children>

        <!-- Title -->
        <Label layoutX="160" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="View Inspection History" textFill="#0c87cf" />

        <!-- Batch ID Input -->
        <Label layoutX="50" layoutY="80" text="Batch ID:" />
        <TextField fx:id="batchIdField" layoutX="150" layoutY="75" prefWidth="200" />

        <Button layoutX="405.0" layoutY="75.0" onAction="#SearchHistory" text="Search" />

        <!-- TableView: Inspection History -->
        <TableView fx:id="historyTable" layoutX="50" layoutY="130" prefHeight="180" prefWidth="500">

            <columns>
                <TableColumn fx:id="colDate" prefWidth="120" text="Date" />
                <TableColumn fx:id="colInspector" prefWidth="120" text="Inspector" />
                <TableColumn fx:id="colResult" prefWidth="120" text="Result" />
                <TableColumn fx:id="colRemarks" prefWidth="140" text="Remarks" />
            </columns>

        </TableView>
        <Button layoutX="457.0" layoutY="349.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />
        <Label fx:id="msglabel" layoutX="195.0" layoutY="341.0" prefHeight="18.0" prefWidth="179.0" />

    </children>
</AnchorPane>