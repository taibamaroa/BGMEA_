
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.ProductionManagergoal7">

    <children>

        <!-- Title -->
        <Label layoutX="140" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Generate Production Report" textFill="#0c87cf" />

        <!-- Report Duration -->
        <Label layoutX="50" layoutY="80" text="From:" />
        <DatePicker fx:id="fromDate" layoutX="120" layoutY="75" />

        <Label layoutX="50" layoutY="120" text="To:" />
        <DatePicker fx:id="toDate" layoutX="120" layoutY="115" />

        <!-- Button -->
        <Button layoutX="120" layoutY="160" onAction="#GenerateReport" text="Generate Report" />

        <!-- Report Summary -->
        <Label layoutX="50" layoutY="210" text="Report Summary:" />
        <TextArea fx:id="reportArea" editable="false" layoutX="50" layoutY="240" prefHeight="58.0" prefWidth="289.0" />

        <!-- Status -->
        <Label fx:id="statusLabel" layoutX="120" layoutY="330" style="-fx-text-fill: red; -fx-font-weight:bold;" text="Status: Waiting" />
        <Button layoutX="419.0" layoutY="326.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />

    </children>
</AnchorPane>
