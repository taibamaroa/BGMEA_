
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.ProductionManagergoal7">

    <children>

        <!-- Title -->
        <Label layoutX="130" layoutY="20" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Optimize Production Efficiency" textFill="#0c87cf" />

        <!-- Button to Analyze -->
        <Button layoutX="337.0" layoutY="195.0" onAction="#AnalyzeBtn" text="Run Efficiency Analysis" />

        <!-- Efficiency Metrics -->
        <Label layoutX="50" layoutY="130" text="Total Production:" />

        <Label layoutX="50" layoutY="160" text="Total Labor Hours:" />

        <Label layoutX="50" layoutY="190" text="Efficiency (%):" />

        <!-- Report Area -->
        <Label layoutX="50" layoutY="230" text="Efficiency Report:" />
        <TextArea fx:id="reportArea" editable="false" layoutX="50" layoutY="260" prefHeight="39.0" prefWidth="227.0" />

        <!-- Status -->
        <Label fx:id="statusLabel" layoutX="200" layoutY="340" style="-fx-text-fill: red; -fx-font-weight:bold;" text="Status: Waiting" />
        <Button layoutX="405.0" layoutY="336.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />
        <TextField fx:id="productionTF" layoutX="180.0" layoutY="126.0" promptText="0" />
        <TextField fx:id="labourTF" layoutX="172.0" layoutY="156.0" promptText="0" />
        <TextField fx:id="efficiencyTF" layoutX="164.0" layoutY="187.0" promptText="0%" />

    </children>
</AnchorPane>
