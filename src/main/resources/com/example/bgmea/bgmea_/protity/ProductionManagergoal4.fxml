<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="489.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bgmea.bgmea_.protity.ProductionManagergoal4">

    <children>

        <!-- Title -->
        <Label layoutX="187.0" layoutY="25.0" style="-fx-font-size:16px; -fx-font-weight:bold;" text="Handle Production Delay" textFill="#0c87cf" />

        <!-- TableView: Delayed Orders -->
        <TableView fx:id="delayTable" layoutX="50.0" layoutY="191.0" prefHeight="111.0" prefWidth="500">

            <columns>
                <TableColumn fx:id="colOrderId" prefWidth="120" text="Order ID" />
                <TableColumn fx:id="colProduct" prefWidth="150" text="Product" />
                <TableColumn fx:id="colDelayDays" prefWidth="120" text="Delay (Days)" />
                <TableColumn fx:id="colStatus" prefWidth="110" text="Status" />
            </columns>

        </TableView>

        <!-- Delay Reason -->
        <Label layoutX="59.0" layoutY="336.0" text="Delay Reason:" />
        <TextArea fx:id="reasonArea" layoutX="147.0" layoutY="326.0" prefHeight="54.0" prefWidth="211.0" />

        <!-- Buttons -->
        <Button layoutX="155.0" layoutY="394.0" onAction="#UpdateDelayBtn" prefHeight="26.0" prefWidth="176.0" text="Update Delay" />

        <!-- Status -->
        <Label fx:id="statusLabel" layoutX="155.0" layoutY="439.0" style="-fx-text-fill: red; -fx-font-weight:bold;" text="Status: Pending" />
        <Label layoutX="60.0" layoutY="75.0" text="Order ID:" />
        <Label layoutX="60.0" layoutY="107.0" text="Product :" />
        <Label layoutX="60.0" layoutY="145.0" text="Delay (Days) :" />
        <TextField fx:id="orderidTF" layoutX="147.0" layoutY="71.0" />
        <TextField fx:id="productTF" layoutX="147.0" layoutY="103.0" />
        <TextField fx:id="daysTF" layoutX="147.0" layoutY="141.0" />
        <Button layoutX="423.0" layoutY="426.0" onAction="#ReturnHomeBtn" text="Return Home" textFill="#0c87cf" />

    </children>
</AnchorPane>